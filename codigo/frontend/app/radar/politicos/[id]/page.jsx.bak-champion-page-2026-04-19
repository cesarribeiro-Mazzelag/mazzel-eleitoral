/**
 * Badge que interpreta a prestação de contas TSE:
 *   - Gasto > Arrecadado = déficit (candidato pagou do proprio bolso ou ficou devendo)
 *   - Gasto ≈ Arrecadado (±2%) = prestação equilibrada
 *   - Gasto < Arrecadado = saldo positivo
 * Evita que o leitor interprete déficit como má gestão sem contexto.
 */
function BadgeSaldoPrestacao({ arrecadado, gasto }) {
  if (arrecadado == null || gasto == null) return null;
  if (arrecadado <= 0 && gasto <= 0) return null;
  const diff = gasto - arrecadado;
  const pctDesvio = arrecadado > 0 ? Math.abs(diff) / arrecadado : 0;

  let estilo, titulo, detalhe;
  if (arrecadado > 0 && pctDesvio <= 0.02) {
    estilo = "bg-gray-50 text-gray-700 border-gray-200";
    titulo = "Prestação equilibrada";
    detalhe = "Gastos e receitas declarados ao TSE em linha (±2%).";
  } else if (diff > 0) {
    estilo = "bg-amber-50 text-amber-900 border-amber-200";
    titulo = `Déficit de ${fmtMoeda(diff)}`;
    detalhe = "Gastou mais do que arrecadou. Candidato declarou recursos próprios ou dívida de campanha ao TSE.";
  } else {
    estilo = "bg-emerald-50 text-emerald-900 border-emerald-200";
    titulo = `Saldo positivo de ${fmtMoeda(-diff)}`;
    detalhe = "Arrecadou mais do que gastou na campanha.";
  }

  return (
    <div className={`rounded-lg border px-2.5 py-1.5 flex items-start gap-2 ${estilo}`}>
      <div className="flex-1 min-w-0">
        <p className="text-[10px] font-bold">{titulo}</p>
        <p className="text-[9px] opacity-80 leading-tight">{detalhe}</p>
      </div>
    </div>
  );
}

