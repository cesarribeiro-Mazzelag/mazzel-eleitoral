function CardComparativos({ comp, cicloAtivo }) {
  const disp = comp?.disponivel === true;

  // Recorte geografico explicito no titulo
  const geo = comp?.escopo === "municipal" && comp?.municipio && comp?.estado_uf
    ? `${comp.municipio}/${comp.estado_uf}`
    : comp?.escopo === "nacional"
      ? "Brasil"
      : comp?.estado_uf ?? "";
  const tituloCtx = comp?.cargo && comp?.ano
    ? `${comp.cargo}${geo ? ` - ${geo}` : ""} - ${comp.ano}`
    : cicloAtivo ? `Ciclo ${cicloAtivo}` : "Sem ciclo";

  // Universo de comparacao em linguagem clara
  const cargoLower = (comp?.cargo || "").toLowerCase();
  const universoTxt = comp?.escopo === "municipal" && comp?.municipio
    ? `Comparado aos candidatos a ${cargoLower} em ${comp.municipio}, no mesmo ciclo.`
    : comp?.escopo === "nacional"
      ? `Comparado aos candidatos a ${cargoLower} no Brasil, no mesmo ciclo.`
      : comp?.estado_uf
        ? `Comparado aos candidatos a ${cargoLower} em ${comp.estado_uf}, no mesmo ciclo.`
        : null;

  if (!disp) {
    return (
      <Bloco titulo={`Comparativos - ${tituloCtx}`} icon={Target} cor="blue" fixedH="180px">
        <SemDados texto={
          comp?.total_candidatos != null && comp.total_candidatos < 3
            ? `Poucos candidatos no ciclo (${comp.total_candidatos})`
            : "Sem dados comparativos pra este ciclo"
        } />
      </Bloco>
    );
  }

  const ordinal = `${comp.posicao_ranking}º`;
  const foiEleito = comp.foi_eleito === true;
  const majoritario = ["PRESIDENTE", "GOVERNADOR", "PREFEITO"].includes((comp.cargo || "").toUpperCase());
  const proporcional = comp.eh_proporcional === true;

  // Badge de resultado
  const resultadoBadge = foiEleito
    ? { label: "ELEITO", cor: "text-green-700", bg: "bg-green-100" }
    : { label: "NAO ELEITO", cor: "text-red-700", bg: "bg-red-100" };

  // Frase de resumo narrativa amarrando tudo
  let resumoFrase = null;
  if (proporcional && foiEleito && comp.quociente_eleitoral) {
    // Proporcional eleito: QE + colocacao no partido
    resumoFrase = `Eleito pelo ${comp.partido_sigla || "partido"}, que somou ${fmt(comp.votos_partido)} votos no cargo (atingiu o quociente eleitoral de ${fmt(comp.quociente_eleitoral)}). Foi o ${comp.colocacao_no_partido}º mais votado do partido, entre ${fmt(comp.total_candidatos_partido)} candidatos.`;
  } else if (proporcional && !foiEleito && comp.quociente_eleitoral) {
    // Proporcional nao eleito: explica se falhou no partido ou no piso individual
    const p = comp.partido_sigla || "partido";
    if (comp.partido_atingiu_qe === false) {
      resumoFrase = `Nao eleito: o ${p} somou ${fmt(comp.votos_partido)} votos e nao atingiu o quociente eleitoral de ${fmt(comp.quociente_eleitoral)}, piso minimo pro partido eleger.`;
    } else if (comp.atingiu_piso_individual === false) {
      resumoFrase = `Nao eleito: mesmo com o ${p} atingindo o quociente, o candidato teve ${fmt(comp.votos_candidato)} votos e nao alcancou o piso individual de ${fmt(comp.piso_individual)} (10% do QE).`;
    } else {
      resumoFrase = `Nao eleito: ${p} atingiu o quociente e o piso individual foi alcancado, mas a distribuicao proporcional das ${fmt(comp.vagas_cargo)} vagas priorizou colegas de chapa. Foi o ${comp.colocacao_no_partido}º mais votado do partido.`;
    }
  } else if (foiEleito && majoritario) {
    resumoFrase = `Ficou em ${ordinal} de ${fmt(comp.total_candidatos)} candidatos e venceu a disputa.`;
  } else if (!foiEleito && majoritario && comp.votos_vencedor) {
    const dif = comp.votos_vencedor - comp.votos_candidato;
    resumoFrase = `Ficou em ${ordinal} de ${fmt(comp.total_candidatos)}. ${comp.vencedor_nome || "O vencedor"} venceu com ${fmt(comp.votos_vencedor)} votos (diferenca de ${fmt(dif)}).`;
  } else if (foiEleito && comp.folga_votos != null) {
    resumoFrase = `Ficou em ${ordinal} de ${fmt(comp.total_candidatos)} candidatos e garantiu uma das ${fmt(comp.vagas_cargo || 1)} vagas.`;
  }

  return (
    <Bloco titulo={`Comparativos - ${tituloCtx}`} icon={Target} cor="blue">
      {universoTxt && (
        <p className="text-[10px] text-gray-500 italic mb-3">{universoTxt}</p>
      )}

      {/* 3 KPIs grandes e auto-explicativos */}
      <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {/* 1 - Votos do candidato */}
        <div className="bg-gray-50 rounded-lg p-3">
          <p className="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Votos recebidos</p>
          <p className="text-3xl font-black text-brand-600 tabular-nums leading-none">{fmt(comp.votos_candidato)}</p>
          <p className="text-[10px] text-gray-500 mt-1">pelo candidato no ciclo</p>
        </div>

        {/* 2 - Colocacao + vagas + resultado */}
        <div className="bg-gray-50 rounded-lg p-3">
          <p className="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Colocacao</p>
          <div className="flex items-baseline gap-1.5">
            <p className={`text-3xl font-black tabular-nums leading-none ${foiEleito ? "text-green-700" : "text-gray-700"}`}>{ordinal}</p>
            <p className="text-sm text-gray-500 tabular-nums">de {fmt(comp.total_candidatos)}</p>
          </div>
          <div className="flex items-center gap-1.5 mt-1.5">
            <span className={`text-[9px] font-bold px-1.5 py-0.5 rounded ${resultadoBadge.bg} ${resultadoBadge.cor}`}>
              {resultadoBadge.label}
            </span>
            {comp.vagas_cargo != null && (
              <span className="text-[10px] text-gray-500">
                {comp.vagas_cargo === 1 ? "1 vaga" : `${fmt(comp.vagas_cargo)} vagas`}
              </span>
            )}
          </div>
        </div>

        {/* 3 - Branch por tipo de cargo */}
        {proporcional && comp.quociente_eleitoral ? (
          // ── Proporcional: Quociente Eleitoral (regra do TSE)
          <div className="bg-gray-50 rounded-lg p-3">
            <p className="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Quociente Eleitoral</p>
            <p className="text-3xl font-black text-gray-800 tabular-nums leading-none">{fmt(comp.quociente_eleitoral)}</p>
            <p className="text-[10px] text-gray-500 mt-0.5">votos minimos pro partido eleger</p>

            <div className="mt-2 pt-2 border-t border-gray-200 space-y-1">
              <div className="flex items-center justify-between gap-2">
                <span className="text-[10px] text-gray-600">
                  {comp.partido_sigla || "Partido"}: <span className="font-bold tabular-nums">{fmt(comp.votos_partido)}</span>
                </span>
                <span className={`text-[9px] font-bold px-1.5 py-0.5 rounded ${comp.partido_atingiu_qe ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"}`}>
                  {comp.partido_atingiu_qe ? "ATINGIU" : "NAO ATINGIU"}
                </span>
              </div>
              <div className="flex items-center justify-between gap-2">
                <span className="text-[10px] text-gray-600">
                  Piso individual (10%): <span className="font-bold tabular-nums">{fmt(comp.piso_individual)}</span>
                </span>
                <span className={`text-[9px] font-bold px-1.5 py-0.5 rounded ${comp.atingiu_piso_individual ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"}`}>
                  {comp.atingiu_piso_individual ? "ATINGIU" : "NAO ATINGIU"}
                </span>
              </div>
              {comp.colocacao_no_partido != null && (
                <p className="text-[10px] text-gray-600 pt-0.5">
                  {comp.colocacao_no_partido}º mais votado do partido (de {fmt(comp.total_candidatos_partido)} candidatos)
                </p>
              )}
            </div>
          </div>
        ) : majoritario && !foiEleito && comp.votos_vencedor != null ? (
          // ── Majoritario nao eleito: mostra o vencedor
          <div className="bg-gray-50 rounded-lg p-3">
            <p className="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Vencedor da eleicao</p>
            <p className="text-base font-black text-gray-800 leading-tight truncate" title={comp.vencedor_nome || ""}>
              {comp.vencedor_nome || "-"}
            </p>
            <p className="text-sm font-bold text-gray-600 tabular-nums mt-0.5">{fmt(comp.votos_vencedor)} votos</p>
            <p className="text-[10px] text-red-600 mt-1 font-semibold tabular-nums">
              -{fmt((comp.votos_vencedor || 0) - (comp.votos_candidato || 0))} de diferenca
            </p>
          </div>
        ) : majoritario && comp.votos_ultimo_eleito != null ? (
          // ── Majoritario eleito: linha de corte (vs 2º colocado)
          <div className="bg-gray-50 rounded-lg p-3">
            <p className="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Margem de vitoria</p>
            <p className="text-3xl font-black text-green-700 tabular-nums leading-none">
              +{fmt((comp.votos_candidato || 0) - (comp.votos_primeiro_nao_eleito || 0))}
            </p>
            <p className="text-[10px] text-gray-500 mt-1">votos a mais que o 2º colocado</p>
            {comp.votos_primeiro_nao_eleito != null && (
              <p className="text-[10px] text-gray-500 mt-0.5 tabular-nums">2º: {fmt(comp.votos_primeiro_nao_eleito)} votos</p>
            )}
          </div>
        ) : (
          <div className="bg-gray-50 rounded-lg p-3">
            <p className="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Contexto do cargo</p>
            <p className="text-sm text-gray-400 mt-2">Nao disponivel</p>
          </div>
        )}
      </div>

      {/* Resumo narrativo */}
      {resumoFrase && (
        <p className="text-[11px] text-gray-700 leading-snug mt-3 bg-blue-50 border-l-2 border-blue-400 px-2.5 py-1.5 rounded-r">
          {resumoFrase}
        </p>
      )}
    </Bloco>
  );
}

function CardRedutos({ redutos }) {
  const disp = redutos?.disponivel === true;
  const lista = redutos?.redutos || [];
  const fracos = redutos?.redutos_fracos || [];

  const subtitulo = redutos?.tipo === "zona"
    ? "Bairros e zonas onde o candidato teve mais votos"
    : redutos?.tipo === "uf"
      ? "Estados onde o candidato teve mais votos"
      : "Municipios onde o candidato teve mais votos";

  if (!disp || lista.length === 0) {
    return (
      <Bloco titulo="Redutos Eleitorais" icon={MapPin} cor="orange" fixedH="520px">
        <SemDados texto="Sem dados de votacao regional pra este ciclo" />
      </Bloco>
    );
  }

  const maxVotos = Math.max(...lista.map(r => r.votos || 0));
  const totalTop5 = lista.reduce((acc, r) => acc + (r.votos || 0), 0);
  const pctTop5 = redutos.total_votos_ciclo > 0
    ? (totalTop5 / redutos.total_votos_ciclo) * 100
    : 0;

  // Perfil territorial -> cor + frase analitica
  const perfilInfo = redutos.perfil_territorial === "concentrado"
    ? { label: "Perfil concentrado", cor: "text-purple-700", bg: "bg-purple-50", desc: "Votacao concentrada em poucas regioes - nicho forte, risco de perder base se migrar" }
    : redutos.perfil_territorial === "equilibrado"
      ? { label: "Perfil equilibrado", cor: "text-green-700", bg: "bg-green-50", desc: "Votacao distribuida entre regioes com concentracao saudavel em nucleos fortes" }
      : { label: "Perfil disperso", cor: "text-blue-700", bg: "bg-blue-50", desc: "Votacao capilarizada em muitas regioes - alta abrangencia territorial" };

  return (
    <Bloco titulo="Redutos Eleitorais" icon={MapPin} cor="orange" fixedH="520px">
      <p className="text-[10px] text-gray-500 italic mb-3">{subtitulo}</p>

      {/* Top 5 fortes */}
      <div>
        <p className="text-[9px] font-bold text-green-700 uppercase tracking-wider mb-1.5">Top 5 redutos</p>
        <div className="space-y-1.5">
          {lista.map((r, i) => {
            const barPct = maxVotos > 0 ? (r.votos / maxVotos) * 100 : 0;
            const pctTotal = (r.pct_do_total * 100).toFixed(1);
            return (
              <div key={i} className="flex items-center gap-2">
                <span className="text-[10px] font-bold text-gray-400 w-4 tabular-nums">{i + 1}</span>
                <div className="flex-1 min-w-0">
                  <div className="flex items-center justify-between gap-2 mb-0.5">
                    <span className="text-[11px] font-semibold text-gray-800 truncate">{r.label}</span>
                    <span className="text-[10px] font-bold text-gray-900 tabular-nums flex-shrink-0">
                      {fmt(r.votos)} <span className="text-[9px] text-gray-500 font-normal">({pctTotal}%)</span>
                    </span>
                  </div>
                  <div className="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                    <div
                      className="h-full bg-orange-400 rounded-full transition-all duration-500"
                      style={{ width: `${Math.max(barPct, 2)}%` }}
                    />
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      {/* Indice de concentracao */}
      {redutos.concentracao_top3_pct != null && (
        <div className={`mt-3 ${perfilInfo.bg} rounded-lg p-2.5`}>
          <div className="flex items-center justify-between gap-2 mb-1">
            <span className={`text-[10px] font-bold uppercase tracking-wider ${perfilInfo.cor}`}>
              {perfilInfo.label}
            </span>
            <span className={`text-lg font-black tabular-nums leading-none ${perfilInfo.cor}`}>
              {redutos.concentracao_top3_pct.toFixed(0)}%
            </span>
          </div>
          <p className="text-[9.5px] text-gray-600 leading-snug">
            Top 3 redutos concentram <span className="font-bold">{redutos.concentracao_top3_pct.toFixed(1)}%</span> dos votos. {perfilInfo.desc}.
          </p>
        </div>
      )}

      {/* Regioes fracas */}
      {fracos.length > 0 && (
        <div className="mt-3">
          <p className="text-[9px] font-bold text-orange-700 uppercase tracking-wider mb-1.5">Onde precisa crescer</p>
          <div className="space-y-1">
            {fracos.map((r, i) => {
              const pctTotal = (r.pct_do_total * 100).toFixed(2);
              return (
                <div key={i} className="flex items-center justify-between text-[10px] text-gray-600">
                  <span className="truncate pr-2">{r.label}</span>
                  <span className="tabular-nums text-gray-500 flex-shrink-0">
                    {fmt(r.votos)} ({pctTotal}%)
                  </span>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* Rodape: alcance territorial */}
      <div className="mt-3 pt-2 border-t border-gray-100 space-y-0.5">
        <p className="text-[10px] text-gray-500">
          Presenca em <span className="font-bold text-gray-800 tabular-nums">{fmt(redutos.total_regioes_com_voto)}</span> {redutos.tipo === "zona" ? "bairros/zonas" : redutos.tipo === "uf" ? "estados" : "municipios"} com voto.
        </p>
        <p className="text-[10px] text-gray-500">
          Top 5 somam <span className="font-bold text-gray-800 tabular-nums">{pctTop5.toFixed(0)}%</span> dos votos ({fmt(redutos.total_votos_ciclo)} no total).
        </p>
      </div>
    </Bloco>
  );
}

function BarraOrigem({ origem }) {
  const fontes = [
    { key: "fundo_partidario_pct", label: "Fundo Partidario", cor: "#3B82F6" },
    { key: "fundo_eleitoral_pct", label: "Fundo Eleitoral", cor: "#8B5CF6" },
    { key: "doacao_privada_pct", label: "Doacao Privada", cor: "#10B981" },
    { key: "recursos_proprios_pct", label: "Recursos Proprios", cor: "#F59E0B" },
    { key: "outros_pct", label: "Outros", cor: "#6B7280" },
  ].filter(f => origem[f.key] != null && origem[f.key] > 0);

  return (
    <div>
      <p className="text-[9px] font-bold text-gray-400 uppercase mb-1.5">Origem dos recursos</p>
      <div className="h-3 rounded-full overflow-hidden flex">
        {fontes.map(f => (
          <div key={f.key} style={{ width: `${(origem[f.key] * 100).toFixed(0)}%`, backgroundColor: f.cor }}
            className="h-full" title={`${f.label}: ${(origem[f.key] * 100).toFixed(1)}%`} />
        ))}
      </div>
      <div className="flex flex-wrap gap-x-3 gap-y-0.5 mt-1">
        {fontes.map(f => (
          <span key={f.key} className="flex items-center gap-1 text-[8px] text-gray-500">
            <span className="w-2 h-2 rounded-full" style={{ backgroundColor: f.cor }} />
            {f.label} {(origem[f.key] * 100).toFixed(0)}%
          </span>
        ))}
      </div>
    </div>
  );
}
